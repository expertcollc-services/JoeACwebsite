{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "dashboard.js",
      "use": "@vercel/static"
    },
    {
      "src": "about/**",
      "use": "@vercel/static"
    },
    {
      "src": "home/**",
      "use": "@vercel/static"
    },
    {
      "src": "commercial-hvac/**",
      "use": "@vercel/static"
    },
    {
      "src": "commercial-refrigeration/**",
      "use": "@vercel/static"
    },
    {
      "src": "service-area/**",
      "use": "@vercel/static"
    },
    {
      "src": "chicago--il/**",
      "use": "@vercel/static"
    },
    {
      "src": "contact/**",
      "use": "@vercel/static"
    },
    {
      "src": "industries/**",
      "use": "@vercel/static"
    },
    {
      "src": "locations/**",
      "use": "@vercel/static"
    },
    {
      "src": "reviews/**",
      "use": "@vercel/static"
    },
    {
      "src": "services/**",
      "use": "@vercel/static"
    },
    {
      "src": "scripts/**",
      "use": "@vercel/static"
    },
    {
      "src": "Scripts/**",
      "use": "@vercel/static"
    },
    {
      "src": "Style/**",
      "use": "@vercel/static"
    },
    {
      "src": "Pages/**",
      "use": "@vercel/static"
    },
    {
      "src": "Resources/**",
      "use": "@vercel/static"
    },
    {
      "src": "robots.txt",
      "use": "@vercel/static"
    },
    {
      "src": "sitemap.xml",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/server.js"
    },
    {
      "src": "/robots.txt",
      "dest": "/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
